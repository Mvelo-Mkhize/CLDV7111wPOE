@model IEnumerable<CLDV7111wPOE.Models.Booking>

<h2>Bookings</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create Booking</a>

    <a asp-action="Availability"
           asp-route-selectedDate="@DateTime.Today.ToString("yyyy-MM-dd")"
           class="btn btn-info">
        Check Today's Availability
    </a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Event</th>
            <th>Venue</th>
            <th>Booking Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Event?.EventName</td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.BookingDate</td>
            </tr>
        }
    </tbody>
</table>