@model IEnumerable<CLDV7111wPOE.Models.Event>

<h2>Events</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create Event</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Organizer</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EventName</td>
                <td>@item.EventDate</td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.OrganizerName</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.EventId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>