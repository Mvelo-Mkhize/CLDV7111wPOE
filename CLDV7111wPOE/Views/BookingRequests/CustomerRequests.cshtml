@model IEnumerable<CLDV7111wPOE.Models.BookingRequest>

<h2>My Booking Requests</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Booking Request
    </a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Event Date</th>
            <th>Venue</th>
            <th>Expected Attendees</th>
            <th>Request Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var request in Model)
        {
            <tr class="@(request.Status == "Pending" ? "table-warning" : request.Status == "Approved" ? "table-success" : "table-danger")">
                <td>@request.EventName</td>
                <td>@request.EventDate.ToString("yyyy-MM-dd")</td>
                <td>@(request.Venue?.VenueName ?? "N/A")</td>
                <td>
                    @if (request.ExpectedAttendees.HasValue)
                    {
                        @request.ExpectedAttendees.Value.ToString("N0")
                        if (request.Venue != null && request.ExpectedAttendees > request.Venue.Capacity)
                        {
                            <span class="badge bg-warning" title="Exceeds venue capacity of @request.Venue.Capacity">⚠️</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </td>
                <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge @(request.Status == "Approved" ? "bg-success" : request.Status == "Denied" ? "bg-danger" : "bg-warning")">
                        @request.Status
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@request.RequestId" class="btn btn-info btn-sm">
                        <i class="bi bi-eye"></i> Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> You haven't made any booking requests yet.
        <a asp-action="Create" class="alert-link">Create your first request</a>.
    </div>
}