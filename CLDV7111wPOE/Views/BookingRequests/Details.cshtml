@model CLDV7111wPOE.Models.BookingRequest
@{
    var role = Context.Session.GetString("UserRole");
}

<h2>Booking Request Details</h2>

<div class="card">
    <div class="card-header @(Model.Status == "Approved" ? "bg-success" : Model.Status == "Denied" ? "bg-danger" : "bg-warning") text-white">
        <h5 class="mb-0">Request #@Model.RequestId - Status: @Model.Status</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h6 class="fw-bold">Event Information</h6>
                <dl class="row">
                    <dt class="col-sm-4">Event Name:</dt>
                    <dd class="col-sm-8">@Model.EventName</dd>

                    <dt class="col-sm-4">Event Date:</dt>
                    <dd class="col-sm-8">@Model.EventDate.ToString("dddd, MMMM d, yyyy")</dd>

                    <dt class="col-sm-4">Expected Attendees:</dt>
                    <dd class="col-sm-8">
                        @if (Model.ExpectedAttendees.HasValue)
                        {
                            @Model.ExpectedAttendees.Value.ToString("N0")
                            if (Model.Venue != null && Model.ExpectedAttendees > Model.Venue.Capacity)
                            {
                                <span class="badge bg-warning ms-2" title="Exceeds venue capacity">Exceeds capacity</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Request Date:</dt>
                    <dd class="col-sm-8">@Model.RequestDate.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>

            <div class="col-md-6">
                <h6 class="fw-bold">Customer Information</h6>
                <dl class="row">
                    <dt class="col-sm-4">Name:</dt>
                    <dd class="col-sm-8">@Model.Customer?.FirstName @Model.Customer?.LastName</dd>

                    <dt class="col-sm-4">Username:</dt>
                    <dd class="col-sm-8">@Model.Customer?.Username</dd>

                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Model.Customer?.Email</dd>
                </dl>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-12">
                <h6 class="fw-bold">Venue Information</h6>
                <dl class="row">
                    <dt class="col-sm-2">Venue:</dt>
                    <dd class="col-sm-10">@Model.Venue?.VenueName</dd>

                    <dt class="col-sm-2">Location:</dt>
                    <dd class="col-sm-10">@Model.Venue?.Location</dd>

                    <dt class="col-sm-2">Capacity:</dt>
                    <dd class="col-sm-10">@Model.Venue?.Capacity.ToString("N0")</dd>

                    <dt class="col-sm-2">Contact:</dt>
                    <dd class="col-sm-10">
                        @if (!string.IsNullOrEmpty(@Model.Venue?.ContactPhone))
                        {
                            <span>Phone: @Model.Venue?.ContactPhone<br /></span>
                        }
                        @if (!string.IsNullOrEmpty(@Model.Venue?.ContactEmail))
                        {
                            <span>Email: @Model.Venue?.ContactEmail</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        @if (Model.Venue?.ImageUrl != null)
        {
            <div class="row mt-3">
                <div class="col-md-12">
                    <h6 class="fw-bold">Venue Image</h6>
                    <img src="@Model.Venue.ImageUrl" alt="@Model.Venue.VenueName" class="img-fluid rounded" style="max-height: 300px;" />
                </div>
            </div>
        }
    </div>
    <div class="card-footer">
        @if (role == "Admin" || role == "Employee")
        {
            <a asp-action="Edit" asp-route-id="@Model.RequestId" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>