@model CLDV7111wPOE.Models.BookingRequest
@{
    var venues = ViewBag.Venues as List<CLDV7111wPOE.Models.Venue>;
    var role = Context.Session.GetString("UserRole");
}

<h2>Edit Booking Request</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="RequestId" />
    <input type="hidden" asp-for="CustomerId" />
    <input type="hidden" asp-for="RequestDate" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Request Details</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EventName" class="control-label fw-bold"></label>
                        <input asp-for="EventName" class="form-control" />
                        <span asp-validation-for="EventName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EventDate" class="control-label fw-bold"></label>
                        <input asp-for="EventDate" type="date" class="form-control" />
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ExpectedAttendees" class="control-label fw-bold"></label>
                        <input asp-for="ExpectedAttendees" type="number" min="1" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="ExpectedAttendees" class="text-danger"></span>
                        <small class="text-muted">Estimated number of attendees (optional)</small>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Customer</label>
                        <input class="form-control" value="@Model.Customer?.FirstName @Model.Customer?.LastName (@Model.Customer?.Username)" readonly />
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="VenueId" class="control-label fw-bold"></label>
                        <select asp-for="VenueId" class="form-control" id="venueSelect">
                            @foreach (var venue in venues)
                            {
                                <option value="@venue.VenueId"
                                        data-capacity="@venue.Capacity"
                                        selected="@(venue.VenueId == Model.VenueId)">
                                    @venue.VenueName - @venue.Location (Capacity: @venue.Capacity)
                                </option>
                            }
                        </select>
                        <span asp-validation-for="VenueId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Status" class="control-label fw-bold"></label>
                        <select asp-for="Status" class="form-control form-select">
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Denied">Denied</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Venue Capacity Check</h5>
        </div>
        <div class="card-body">
            <div id="venueCapacityInfo" class="alert alert-info">
                <strong>Venue Capacity:</strong> <span id="selectedVenueCapacity">@(Model.Venue?.Capacity ?? 0)</span>
            </div>
            <div id="attendeeWarning" class="alert alert-warning" style="display: @(Model.ExpectedAttendees.HasValue && Model.Venue != null && Model.ExpectedAttendees > Model.Venue.Capacity ? "block" : "none")">
                <strong>Warning:</strong> Expected attendees (@Model.ExpectedAttendees) exceed the venue's capacity (@(Model.Venue?.Capacity ?? 0))!
            </div>
        </div>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Save Changes
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#venueSelect').change(function() {
                var selectedOption = $(this).find('option:selected');
                var capacity = selectedOption.data('capacity');
                var expectedAttendees = $('#ExpectedAttendees').val();
                
                if (capacity) {
                    $('#selectedVenueCapacity').text(capacity);
                    
                    if (expectedAttendees && parseInt(expectedAttendees) > parseInt(capacity)) {
                        $('#attendeeWarning').show();
                    } else {
                        $('#attendeeWarning').hide();
                    }
                }
            });

            $('#ExpectedAttendees').on('input', function() {
                var expected = $(this).val();
                var selectedOption = $('#venueSelect').find('option:selected');
                var capacity = selectedOption.data('capacity');
                
                if (capacity && expected && parseInt(expected) > parseInt(capacity)) {
                    $('#attendeeWarning').show();
                } else {
                    $('#attendeeWarning').hide();
                }
            });
        });
    </script>
    
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}